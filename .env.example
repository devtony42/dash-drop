# dash-drop environment variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# -----------------------------------------------------------------------
# Database (PostgreSQL)
# Docker Compose wires this automatically. Change only if using an
# external database.
# -----------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@db:5432/crud_dashboard
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=crud_dashboard

# -----------------------------------------------------------------------
# JWT Authentication
# REQUIRED in production — generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# The server logs a warning on startup if this is left as the default.
# -----------------------------------------------------------------------
JWT_SECRET=change-me-to-a-random-secret-in-production

# -----------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------
PORT=3001
NODE_ENV=development

# -----------------------------------------------------------------------
# Client (Vite)
# In Docker Compose the client proxies through Vite dev server, so
# VITE_API_URL is only needed when running the client outside Docker.
# -----------------------------------------------------------------------
VITE_API_URL=http://localhost:3001/api

# -----------------------------------------------------------------------
# Advanced (optional)
# Override default file locations if you keep config outside the repo root.
# -----------------------------------------------------------------------
# SCHEMA_PATH=/path/to/schema.config.json
# PRISMA_SCHEMA_PATH=/path/to/prisma/schema.prisma
